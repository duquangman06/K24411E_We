<html>
<head>
    <title>GET Result</title>

    <style>
        body{
            background-color: #f2f2f2;
            font-family: "Times New Roman";
        }

        .box{
            width: 600px;
            margin: auto;
            margin-top: 50px;
            background-color: white;
            border: 2px solid gray;
            padding: 20px;
        }

        h2{
            text-align: center;
            color: darkblue;
        }

        p{
            font-size: 22px;
        }
    </style>
</head>

<body>

    <div class="box">

        <h2>Message Information</h2>

        <p>
            <b>Full Name:</b>

            <script>
                document.write(
                    new URLSearchParams(window.location.search)
                    .get("fullname")
                );
            </script>
        </p>

        <p>
            <b>Email:</b>

            <script>
                document.write(
                    new URLSearchParams(window.location.search)
                    .get("email")
                );
            </script>
        </p>

        <p>
            <b>Department:</b>

            <script>
                document.write(
                    new URLSearchParams(window.location.search)
                    .get("department")
                );
            </script>
        </p>

        <p>
            <b>Title:</b>

            <script>
                document.write(
                    new URLSearchParams(window.location.search)
                    .get("title")
                );
            </script>
        </p>

        <p>
            <b>Content:</b>

            <script>
                document.write(
                    new URLSearchParams(window.location.search)
                    .get("content")
                );
            </script>
        </p>

    </div>

</body>
</html>
